generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model appointments {
  appointment_id                     Int          @id @default(autoincrement())
  user_id                            Int?
  vaccine_id                         Int?
  status                             status_enum?
  notes                              String?
  dose_number                        Int?
  created_at                         DateTime?
  completed_at                       DateTime?
  side_effects                       String?
  staff_id                           Int?
  users_appointments_user_idTousers  users?       @relation("appointments_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vaccines                           vaccines?    @relation(fields: [vaccine_id], references: [vaccine_id], onDelete: NoAction, onUpdate: NoAction)
  users_appointments_staff_idTousers users?       @relation("appointments_staff_idTousers", fields: [staff_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_appointments_users")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model message_medias {
  message_id Int?
  media_file String?   @db.VarChar(300)
  id         Int       @id @default(autoincrement())
  messages   messages? @relation(fields: [message_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model messages {
  id                                     Int              @id @default(autoincrement())
  asked_user_id                          Int?
  response_user_id                       Int?
  content                                String?
  role                                   String?
  created_at                             DateTime  @default(now())
  message_medias                         message_medias[]
  users_messages_asked_user_idTousers    users?           @relation("messages_asked_user_idTousers", fields: [asked_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_messages_response_user_idTousers users?           @relation("messages_response_user_idTousers", fields: [response_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model notifications {
  notification_id Int       @id @default(autoincrement())
  user_id         Int?
  content         String?
  send_date       DateTime? @db.Date
  is_read         Boolean?
  users           users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  id                                        Int             @id @default(autoincrement())
  fullname                                  String?         @db.VarChar(100)
  date_of_birth                             DateTime?       @db.Date
  gender                                    String?         @db.Bit(1)
  role                                      String          @db.VarChar(20)
  created_at                                DateTime?       @default(now()) @db.Timestamp(6)
  email                                     String          @unique @db.Char(250)
  password                                  String
  appointments_appointments_user_idTousers  appointments[]  @relation("appointments_user_idTousers")
  appointments_appointments_staff_idTousers appointments[]  @relation("appointments_staff_idTousers")
  messages_messages_asked_user_idTousers    messages[]      @relation("messages_asked_user_idTousers")
  messages_messages_response_user_idTousers messages[]      @relation("messages_response_user_idTousers")
  notifications                             notifications[]
}

model vaccines {
  vaccine_id      Int            @id @default(autoincrement())
  name            String?        @db.VarChar(100)
  manufacturer    String?        @db.VarChar(100)
  price           String?        @db.VarChar(50)
  description     String?
  dosage          String?        @db.VarChar(50)
  number_of_doses Int?
  expiry_date     DateTime?      @db.Date
  stock_quantity  Int?
  gender          String?        @db.Bit(1)
  age_range       String?
  appointments    appointments[]
}

model OTP {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum status_enum {
  DXL @map("Đang xử lý")
  HT  @map("Đã hoàn thành")
  Huy @map("Đã Huỷ")
}

